{
  "name": "markdown-editor",
  "version": "1.0.0",
  "description": "Web-based WYSIWYG Markdown editor for offline use",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:release": "node scripts/build-singlefile.mjs",
    "verify:offline": "node scripts/verify-offline-build.mjs",
    "preview": "vite preview",
    "test:unit": "node --test",
    "test:ui": "node tests/ui/offline-editor.mjs"
  },

  "dependencies": {
    "@milkdown/core": "7.21.3",
    "@milkdown/crepe": "7.21.3",
    "dompurify": "3.4.12",
    "marked": "18.0.6"
  },
  "devDependencies": {
    "playwright-core": "1.61.1",
    "vite": "8.1.4",
    "vite-plugin-singlefile": "2.3.3"
  },
  "overrides": {
    "lodash-es": "4.18.1",
    "postcss": "8.5.18"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
